#include <iostream>
using namespace std;
long long factorial(int n) {
    long long fact = 1;
    for(int i = 1; i <= n; i++) fact *= i;
    return fact;
}
int main() {
int num;
cout << "enter a number:";
cin >> num;
    cout << "Factorial: " << factorial(num) << endl;
    return 0;
}

