#include <iostream>
using namespace std;
int getMax(int a, int b) {
    return (a > b) ? a : b;
}
int main() {
    int num1, num2;
    cout << "Enter two numbers: ";
    cin >> num1 >> num2;
    cout << "Max: " << getMax(num1, num2) << endl;   
    return 0;
}

