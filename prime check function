#include <iostream>
using namespace std;
int isPrime(int n) {
    if (n <= 1) return 0; 
    for (int i = 2; i * i <= n; i++) {
        if (n % i == 0) return 0;
    }
    return 1;
    }
int main() {
    int num;
    cout << "Enter a number: ";
    cin >> num;
    if (isPrime(num) == 1) {
        cout << num << " is a Prime number." << endl;
    } else {
        cout << num << " is not a Prime number." << endl;
    }
    return 0;
}

