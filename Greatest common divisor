#include <iostream>
using namespace std;
int gcd(int a, int b) {
    while (b != 0) {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int main() {
int num1,num2;
cout << "enter a number:";
cin >> num1;
cout << "enter second number:";
cin >> num2;
 cout << "GCD: " << gcd(num1,num2) << endl;
 return 0;
}

